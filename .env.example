# Vibes App - Environment Variables
# Copy to .env and fill in your Clerk key.
# Connect URLs are auto-provisioned on first deploy.

# OIDC Authentication (Pocket ID)
# From your Connect Studio's Pocket ID configuration
VITE_OIDC_AUTHORITY=https://your-studio.exe.xyz/auth
VITE_OIDC_CLIENT_ID=your-client-id-here

# Fireproof Connect (auto-provisioned on deploy — do not set manually)
# VITE_API_URL=https://...
# VITE_CLOUD_URL=fpcloud://...
