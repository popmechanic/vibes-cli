# Fireproof Connect - Environment Variables
# Generated by /vibes:connect skill
# Copy to .env and fill in your values

# OIDC Authentication (Pocket ID)
# From your Connect Studio's Pocket ID configuration
VITE_OIDC_AUTHORITY=https://your-studio.exe.xyz/auth
VITE_OIDC_CLIENT_ID=your-client-id-here

# Fireproof Connect (your studio VM)
# Set up with /vibes:connect
VITE_API_URL=https://your-studio.exe.xyz/api/
VITE_CLOUD_URL=fpcloud://your-studio.exe.xyz?protocol=wss
